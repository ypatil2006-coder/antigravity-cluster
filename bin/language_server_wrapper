#!/bin/bash
new_args=()
skip_next=false

export HOME="$REAL_HOME/.config/Antigravity-Profiles/$ANTIGRAVITY_PROFILE/HOME"

for ((i=1; i<=$#; i++)); do
    arg="${!i}"
    
    if [ "$arg" = "--app_data_dir" ]; then
        new_args+=("$arg")
        # Check if the next argument exists
        next_idx=$((i+1))
        if [ $next_idx -le $# ]; then
            next_arg="${!next_idx}"
            new_args+=("${next_arg}-$ANTIGRAVITY_PROFILE")
            skip_next=true
        fi
    elif [ "$skip_next" = true ]; then
        skip_next=false
    else
        new_args+=("$arg")
    fi
done

exec /tmp/language_server.real "${new_args[@]}"
